<Window x:Class="Dock.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Dock.App.Controls"
        Title="Rock ET Dock - Configuracoes"
        Width="680"
        Height="560"
        MinWidth="620"
        MinHeight="500"
        Icon="Assets/rock-et-dock-icon.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <controls:BrandLogo Width="56"
                                Height="56"
                                DockPanel.Dock="Left"
                                Margin="0,0,12,0" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Rock ET Dock" />
                <TextBlock Foreground="#666"
                           Text="{Binding BarNameText}" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Geral">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Nome da barra" />
                        <TextBox x:Name="BarNameBox" Margin="0,4,0,12" />

                        <CheckBox x:Name="RunAtStartupBox"
                                  Margin="0,0,0,8"
                                  Content="Carregar na inicializacao do Windows" />
                        <CheckBox x:Name="LockItemsBox"
                                  Margin="0,0,0,8"
                                  Content="Travar itens da barra" />
                        <CheckBox x:Name="AutoHideBox"
                                  Margin="0,0,0,8"
                                  Content="Auto-ocultar" />
                        <CheckBox x:Name="WindowsButtonBox"
                                  Margin="0,0,0,8"
                                  Content="Adicionar botao Windows na barra" />
                        <CheckBox x:Name="RecycleBinBox"
                                  Margin="0,0,0,8"
                                  Content="Adicionar lixeira na barra" />
                        <CheckBox x:Name="HideNativeTaskbarBox"
                                  Margin="0,0,0,8"
                                  Content="Esconder a barra nativa do Windows enquanto o Rock ET Dock estiver aberto" />

                        <TextBlock Margin="0,10,0,0" Text="Ao adicionar arquivos e pastas" />
                        <ComboBox x:Name="ImportModeBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Margin="0,10,0,0" Text="Delay do auto-ocultar (ms)" />
                        <Slider x:Name="AutoHideDelaySlider"
                                Minimum="0"
                                Maximum="2000"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Duracao do auto-ocultar (ms)" />
                        <Slider x:Name="AutoHideDurationSlider"
                                Minimum="0"
                                Maximum="800"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,8" />

                        <TextBlock Margin="0,12,0,0" Text="Pasta da barra" />
                        <TextBox x:Name="BarFolderBox"
                                 Margin="0,4,0,0"
                                 IsReadOnly="True" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Icones">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Tamanho" />
                        <Slider x:Name="IconSizeSlider"
                                Minimum="12"
                                Maximum="96"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Opacidade" />
                        <Slider x:Name="IconOpacitySlider"
                                Minimum="15"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <CheckBox x:Name="HideLabelsBox"
                                  Margin="0,0,0,12"
                                  Content="Ocultar texto dos icones" />

                        <TextBlock Text="Espacamento entre icones" />
                        <Slider x:Name="IconSpacingSlider"
                                Minimum="0"
                                Maximum="40"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Margem inferior dos icones" />
                        <Slider x:Name="IconBottomMarginSlider"
                                Minimum="0"
                                Maximum="60"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Qualidade" />
                        <ComboBox x:Name="IconQualityBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <CheckBox x:Name="ZoomEnabledBox"
                                  Margin="0,0,0,8"
                                  Content="Ampliar ao passar o mouse" />
                        <CheckBox x:Name="ZoomOpaqueBox"
                                  Margin="0,0,0,12"
                                  Content="Icone opaco durante ampliacao" />

                        <TextBlock Text="Tamanho da ampliacao" />
                        <Slider x:Name="ZoomSizeSlider"
                                Minimum="16"
                                Maximum="128"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Alcance da ampliacao" />
                        <Slider x:Name="ZoomRangeSlider"
                                Minimum="1"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Tempo da ampliacao (ms)" />
                        <Slider x:Name="ZoomDurationSlider"
                                Minimum="60"
                                Maximum="500"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Efeito hover" />
                        <ComboBox x:Name="HoverEffectBox"
                                  Margin="0,4,0,0"
                                  SelectedValuePath="Value" />

                        <Button Margin="0,16,0,0"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                Click="AddGif_Click"
                                Content="Adicionar GIF animado..." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Posicao">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Monitor" />
                        <ComboBox x:Name="MonitorBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="Lado da tela" />
                        <ComboBox x:Name="EdgeBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="Sobreposicao" />
                        <ComboBox x:Name="LayeringBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="Largura da barra (0 = automatica)" />
                        <Slider x:Name="BarWidthSlider"
                                Minimum="0"
                                Maximum="1800"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Altura da barra (0 = automatica)" />
                        <Slider x:Name="BarHeightSlider"
                                Minimum="0"
                                Maximum="320"
                                TickFrequency="4"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Distancia da borda" />
                        <Slider x:Name="OffsetSlider"
                                Minimum="-220"
                                Maximum="200"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Centralizacao" />
                        <Slider x:Name="CenterOffsetSlider"
                                Minimum="-800"
                                Maximum="800"
                                TickFrequency="10"
                                TickPlacement="BottomRight"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,2" />
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="#777"
                                   FontSize="11"
                                   Text="0 = centro absoluto" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Estilo">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="Tema" />
                        <ComboBox x:Name="ThemeBox" Margin="0,4,0,12" />

                        <TextBlock Text="Opacidade do fundo" />
                        <Slider x:Name="BackgroundOpacitySlider"
                                Minimum="15"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Arredondamento da barra" />
                        <Slider x:Name="ShellCornerRadiusSlider"
                                Minimum="0"
                                Maximum="36"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Arredondamento do fundo dos icones" />
                        <Slider x:Name="TileCornerRadiusSlider"
                                Minimum="0"
                                Maximum="24"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Fonte" />
                        <TextBox x:Name="FontFamilyBox" Margin="0,4,0,12" />

                        <TextBlock Text="Tamanho da fonte" />
                        <Slider x:Name="FontSizeSlider"
                                Minimum="7"
                                Maximum="16"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Cor da legenda" />
                        <TextBox x:Name="LabelColorBox" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Comportamento">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <CheckBox x:Name="MinimizeWindowsBox"
                                  Margin="0,0,0,8"
                                  ToolTip="Adiciona janelas minimizadas como itens temporarios na barra."
                                  Content="Minimizar janelas para a barra" />
                        <CheckBox x:Name="DisableMinimizeAnimationsBox"
                                  Margin="0,0,0,8"
                                  IsEnabled="False"
                                  ToolTip="Depende da implementacao de minimizar janelas para a barra."
                                  Content="Desativar animacoes de minimizar (em breve)" />
                        <CheckBox x:Name="ShowRunningIndicatorsBox"
                                  Margin="0,0,0,8"
                                  IsEnabled="False"
                                  ToolTip="Depende do monitoramento de processos/janelas."
                                  Content="Mostrar indicadores de apps abertos (em breve)" />
                        <CheckBox x:Name="OpenRunningInstancesBox"
                                  Margin="0,0,0,8"
                                  IsEnabled="False"
                                  ToolTip="Depende do mapeamento entre itens e janelas abertas."
                                  Content="Abrir instancia existente quando possivel (em breve)" />
                        <CheckBox x:Name="PopupOnMouseoverBox"
                                  Margin="0,0,0,12"
                                  Content="Mostrar barra ao passar o mouse" />

                        <TextBlock Text="Delay do popup (ms)" />
                        <Slider x:Name="PopupDelaySlider"
                                Minimum="0"
                                Maximum="1500"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="#666"
                       Text="{Binding ConfigPathText}"
                       TextTrimming="CharacterEllipsis" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Width="92"
                        Margin="0,0,8,0"
                        Click="Close_Click"
                        Content="Fechar" />
                <Button Width="128"
                        IsDefault="True"
                        Click="Save_Click"
                        Content="Salvar e fechar" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
