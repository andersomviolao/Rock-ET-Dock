<Window x:Class="Dock.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Dock.App.Controls"
        Title="{Binding Text[SettingsWindowTitle]}"
        Width="680"
        Height="560"
        MinWidth="620"
        MinHeight="500"
        Icon="Assets/rock-et-dock-icon.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <controls:BrandLogo Width="56"
                                Height="56"
                                DockPanel.Dock="Left"
                                Margin="0,0,12,0" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Rock ET Dock" />
                <TextBlock Foreground="#666"
                           Text="{Binding BarNameText}" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="{Binding Text[SettingsGeneralTab]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="{Binding Text[SettingsBarName]}" />
                        <TextBox x:Name="BarNameBox" Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsLanguage]}" />
                        <ComboBox x:Name="LanguageBox"
                                  DisplayMemberPath="Label"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <CheckBox x:Name="RunAtStartupBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsRunAtStartup]}" />
                        <CheckBox x:Name="LockItemsBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsLockItems]}" />
                        <CheckBox x:Name="AutoHideBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsAutoHide]}" />
                        <CheckBox x:Name="WindowsButtonBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsWindowsButton]}" />
                        <CheckBox x:Name="RecycleBinBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsRecycleBin]}" />
                        <CheckBox x:Name="HideNativeTaskbarBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsHideNativeTaskbar]}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding Text[SettingsMoveModifierKey]}"
                                   TextWrapping="Wrap" />
                        <ComboBox x:Name="MoveModifierBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding Text[SettingsGifModifierKey]}"
                                   TextWrapping="Wrap" />
                        <ComboBox x:Name="GifModifierBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Margin="0,10,0,0" Text="{Binding Text[SettingsAutoHideDelay]}" />
                        <Slider x:Name="AutoHideDelaySlider"
                                Minimum="0"
                                Maximum="2000"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsAutoHideDuration]}" />
                        <Slider x:Name="AutoHideDurationSlider"
                                Minimum="0"
                                Maximum="800"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,8" />

                        <TextBlock Margin="0,12,0,0" Text="{Binding Text[SettingsBarFolder]}" />
                        <TextBox x:Name="BarFolderBox"
                                 Margin="0,4,0,0"
                                 IsReadOnly="True" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Text[SettingsIconsTab]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="{Binding Text[SettingsIconSize]}" />
                        <Slider x:Name="IconSizeSlider"
                                Minimum="12"
                                Maximum="96"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsIconOpacity]}" />
                        <Slider x:Name="IconOpacitySlider"
                                Minimum="15"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <CheckBox x:Name="HideLabelsBox"
                                  Margin="0,0,0,12"
                                  Content="{Binding Text[SettingsHideLabels]}" />

                        <TextBlock Text="{Binding Text[SettingsIconSpacing]}" />
                        <Slider x:Name="IconSpacingSlider"
                                Minimum="0"
                                Maximum="40"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsIconBottomMargin]}" />
                        <Slider x:Name="IconBottomMarginSlider"
                                Minimum="0"
                                Maximum="60"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsIconQuality]}" />
                        <ComboBox x:Name="IconQualityBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <CheckBox x:Name="ZoomEnabledBox"
                                  Margin="0,0,0,8"
                                  Content="{Binding Text[SettingsZoomEnabled]}" />
                        <CheckBox x:Name="ZoomOpaqueBox"
                                  Margin="0,0,0,12"
                                  Content="{Binding Text[SettingsZoomOpaque]}" />

                        <TextBlock Text="{Binding Text[SettingsZoomSize]}" />
                        <Slider x:Name="ZoomSizeSlider"
                                Minimum="16"
                                Maximum="128"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsZoomRange]}" />
                        <Slider x:Name="ZoomRangeSlider"
                                Minimum="1"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsZoomDuration]}" />
                        <Slider x:Name="ZoomDurationSlider"
                                Minimum="60"
                                Maximum="500"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsHoverEffect]}" />
                        <ComboBox x:Name="HoverEffectBox"
                                  Margin="0,4,0,0"
                                  SelectedValuePath="Value" />

                        <Button Margin="0,16,0,0"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                Click="AddGif_Click"
                                Content="{Binding Text[SettingsAddAnimatedGif]}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Text[SettingsPositionTab]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="{Binding Text[SettingsMonitor]}" />
                        <ComboBox x:Name="MonitorBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="{Binding Text[SettingsEdge]}" />
                        <ComboBox x:Name="EdgeBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="{Binding Text[SettingsLayering]}" />
                        <ComboBox x:Name="LayeringBox"
                                  Margin="0,4,0,12"
                                  SelectedValuePath="Value" />

                        <TextBlock Text="{Binding Text[SettingsBarWidth]}" />
                        <Slider x:Name="BarWidthSlider"
                                Minimum="0"
                                Maximum="1800"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsBarHeight]}" />
                        <Slider x:Name="BarHeightSlider"
                                Minimum="0"
                                Maximum="320"
                                TickFrequency="4"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsOffset]}" />
                        <Slider x:Name="OffsetSlider"
                                Minimum="-220"
                                Maximum="200"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsCenterOffset]}" />
                        <Slider x:Name="CenterOffsetSlider"
                                Minimum="-800"
                                Maximum="800"
                                TickFrequency="10"
                                TickPlacement="BottomRight"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,2" />
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="#777"
                                   FontSize="11"
                                   Text="{Binding Text[SettingsCenterHint]}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Text[SettingsStyleTab]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="{Binding Text[SettingsTheme]}" />
                        <ComboBox x:Name="ThemeBox" Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsBackgroundOpacity]}" />
                        <Slider x:Name="BackgroundOpacitySlider"
                                Minimum="15"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsShellCornerRadius]}" />
                        <Slider x:Name="ShellCornerRadiusSlider"
                                Minimum="0"
                                Maximum="36"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsTileCornerRadius]}" />
                        <Slider x:Name="TileCornerRadiusSlider"
                                Minimum="0"
                                Maximum="24"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsFontFamily]}" />
                        <TextBox x:Name="FontFamilyBox" Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsFontSize]}" />
                        <Slider x:Name="FontSizeSlider"
                                Minimum="7"
                                Maximum="16"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding Text[SettingsLabelColor]}" />
                        <TextBox x:Name="LabelColorBox" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Text[SettingsBehaviorTab]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <CheckBox x:Name="MinimizeWindowsBox"
                                  Margin="0,0,0,8"
                                  ToolTip="{Binding Text[SettingsMinimizeWindowsTooltip]}"
                                  Content="{Binding Text[SettingsMinimizeWindows]}" />
                        <CheckBox x:Name="DisableMinimizeAnimationsBox"
                                  Margin="0,0,0,8"
                                  IsEnabled="False"
                                  ToolTip="{Binding Text[SettingsDisableMinimizeAnimationsTooltip]}"
                                  Content="{Binding Text[SettingsDisableMinimizeAnimations]}" />
                        <CheckBox x:Name="ShowRunningIndicatorsBox"
                                  Margin="0,0,0,8"
                                  ToolTip="{Binding Text[SettingsShowRunningIndicatorsTooltip]}"
                                  Content="{Binding Text[SettingsShowRunningIndicators]}" />
                        <CheckBox x:Name="OpenRunningInstancesBox"
                                  Margin="0,0,0,8"
                                  ToolTip="{Binding Text[SettingsOpenRunningInstancesTooltip]}"
                                  Content="{Binding Text[SettingsOpenRunningInstances]}" />
                        <CheckBox x:Name="PopupOnMouseoverBox"
                                  Margin="0,0,0,12"
                                  Content="{Binding Text[SettingsPopupOnMouseover]}" />

                        <TextBlock Text="{Binding Text[SettingsPopupDelay]}" />
                        <Slider x:Name="PopupDelaySlider"
                                Minimum="0"
                                Maximum="1500"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="#666"
                       Text="{Binding ConfigPathText}"
                       TextTrimming="CharacterEllipsis" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Width="92"
                        Click="Close_Click"
                        Content="{Binding Text[SettingsClose]}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
