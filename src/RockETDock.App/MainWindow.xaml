<Window x:Class="RockETDock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RockETDock.App.Controls"
        Title="Rock ET Dock"
        Width="520"
        Height="88"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Topmost="True"
        Icon="Assets/rock-et-dock-icon.ico"
        ClipToBounds="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="DockItemButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="DockRoot"
          Background="Transparent"
          ClipToBounds="False">
        <Border x:Name="DockShell"
                AllowDrop="True"
                Background="{Binding ShellBackground}"
                BorderBrush="{Binding ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="{Binding ShellCornerRadius}"
                ClipToBounds="False"
                Margin="{Binding DockShellMargin}"
                Padding="10"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="{Binding ShadowOpacity}"
                                  ShadowDepth="6" />
            </Border.Effect>

            <ItemsControl x:Name="DockItemsControl"
                          ClipToBounds="False"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel ClipToBounds="False"
                                    Orientation="{Binding DataContext.Orientation, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="{Binding DataContext.ItemButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                Height="{Binding DataContext.ItemButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource DockItemButtonStyle}"
                                Margin="{Binding DataContext.ItemMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"
                                Click="DockItem_Click"
                                AllowDrop="True"
                                PreviewMouseLeftButtonDown="DockItem_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="DockItem_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="DockItem_PreviewMouseMove"
                                PreviewMouseRightButtonDown="DockItem_PreviewMouseRightButtonDown"
                                PreviewMouseRightButtonUp="DockItem_PreviewMouseRightButtonUp"
                                ContextMenuOpening="DockItem_ContextMenuOpening"
                                GiveFeedback="DockItem_GiveFeedback"
                                MouseEnter="DockItem_MouseEnter"
                                MouseLeave="DockItem_MouseLeave"
                                DragOver="DockItem_DragOver"
                                Drop="DockItem_Drop"
                                RenderTransformOrigin="0.5,0.5"
                                Visibility="{Binding ButtonVisibility}"
                                ToolTip="{Binding DisplayName}">
                            <Button.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                    <TranslateTransform X="0" Y="0" />
                                </TransformGroup>
                            </Button.RenderTransform>
                            <Grid ClipToBounds="False">
                                <Grid ClipToBounds="False"
                                      Margin="{Binding DataContext.ItemContentMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Visibility="{Binding ContentVisibility}"
                                      Opacity="{Binding DragOpacity}">
                                    <Grid.RenderTransform>
                                        <TranslateTransform Y="{Binding DataContext.ItemContentOffsetY, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Grid.RenderTransform>
                                    <Border Width="{Binding DataContext.IconTileSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="{Binding DataContext.IconTileSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Background="{Binding DataContext.TileBackground, RelativeSource={RelativeSource AncestorType=Window}}"
                                            BorderBrush="{Binding DataContext.TileBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                            BorderThickness="1"
                                            CornerRadius="{Binding DataContext.TileCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Image Width="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Height="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="{Binding DataContext.ItemOpacity, RelativeSource={RelativeSource AncestorType=Window}}"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="{Binding Icon}"
                                           Visibility="{Binding StaticIconVisibility}" />
                                    <controls:AnimatedGifImage Width="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               Height="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Opacity="{Binding DataContext.ItemOpacity, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               SourcePath="{Binding Item.TargetPath}"
                                                               Stretch="Uniform"
                                                               Visibility="{Binding AnimatedGifVisibility}" />
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,4,3"
                                               FontFamily="{Binding DataContext.Bar.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="{Binding DataContext.LabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="{Binding DataContext.LabelBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MaxWidth="{Binding DataContext.LabelMaxWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Text="{Binding ShortLabel}"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding DataContext.LabelVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Ellipse Width="8"
                                             Height="8"
                                             Margin="0,0,8,8"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Bottom"
                                             Fill="#54F18C"
                                             Stroke="#D8FFE6"
                                             StrokeThickness="1"
                                             Visibility="{Binding RunningIndicatorVisibility}" />
                                </Grid>
                                <Border Width="{Binding DataContext.SeparatorWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Height="{Binding DataContext.SeparatorHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{Binding DataContext.SeparatorBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CornerRadius="2"
                                        Opacity="{Binding DragOpacity}"
                                        Visibility="{Binding SeparatorVisibility}" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
